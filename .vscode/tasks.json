{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "🔧 Configure Project",
            "type": "shell", 
            "command": "python3",            "dependsOn": [
                "📡 Switch to Node Mode",
                "🧹 Clean CMake Cache", 
                "⚙️ Configure CMake"
            ],        "args": [
                "config_manager.py",
                "configure"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "📝 Generate Config Headers",
            "type": "shell",
            "command": "python3", 
            "args": [
                "config_manager.py",
                "generate"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "silent",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "🧹 Clean CMake Cache",
            "type": "shell",
            "command": "rm",
            "args": [
                "-rf",
                "build/Debug"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "silent",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "⚙️ Configure CMake",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-B",
                "build/Debug",
                "-S",
                ".",
                "-DCMAKE_BUILD_TYPE=Debug"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "silent",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "🏭 Switch to Gateway Mode",
            "type": "shell",
            "command": "bash",
            "args": [
                "-c",
                "sed -i 's/\"mode\": \"NODE\"/\"mode\": \"GATEWAY\"/' config.json && python3 config_manager.py"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "silent",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "📡 Switch to Node Mode", 
            "type": "shell",
            "command": "bash",
            "args": [
                "-c",
                "sed -i 's/\"mode\": \"GATEWAY\"/\"mode\": \"NODE\"/' config.json && python3 config_manager.py"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "silent",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Build Gateway",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "build/Debug",
                "--target",
                "SubGHz_Phy_PingPong_Gateway"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "dependsOn": [
                "🏭 Switch to Gateway Mode",
                "🧹 Clean CMake Cache",
                "⚙️ Configure CMake"
            ],
            "dependsOrder": "sequence",
            "problemMatcher": ["$gcc"],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            }
        },
        {
            "label": "STM32: Clean",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "build/Debug",
                "--target",
                "clean"
            ],
            "group": "build"
        },
        {
            "label": "Build Node",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "build/Debug",
                "--target",
                "SubGHz_Phy_PingPong_Node"
            ],
            "group": "build",
            "dependsOn": [
                "� Switch to Node Mode",
                "🧹 Clean CMake Cache", 
                "⚙️ Configure CMake"
            ],
            "dependsOrder": "sequence",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared"
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "⚡ Quick Build Gateway",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "build/Debug",
                "--target",
                "SubGHz_Phy_PingPong_Gateway"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "⚡ Quick Build Node", 
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "build/Debug",
                "--target",
                "SubGHz_Phy_PingPong_Node"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "🔄 Full Clean & Build Gateway",
            "type": "shell",
            "command": "echo",
            "args": ["Running Full Gateway Build..."],
            "group": "build",
            "dependsOn": [
                "🏭 Switch to Gateway Mode",
                "🧹 Clean CMake Cache",
                "⚙️ Configure CMake",
                "⚡ Quick Build Gateway"
            ],
            "dependsOrder": "sequence",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            }
        },
        {
            "label": "🔄 Full Clean & Build Node",
            "type": "shell", 
            "command": "echo",
            "args": ["Running Full Node Build..."],
            "group": "build",
            "dependsOn": [
                "📡 Switch to Node Mode",
                "🧹 Clean CMake Cache",
                "⚙️ Configure CMake", 
                "⚡ Quick Build Node"
            ],
            "dependsOrder": "sequence",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            }
        },
        {
            "label": "📊 Show Current Build Mode",
            "type": "shell",
            "command": "bash",
            "args": [
                "-c",
                "echo '=== Current Configuration ===' && grep '\"mode\"' config.json && echo '=== Build Artifacts ===' && ls -la build/Debug/*.elf 2>/dev/null || echo 'No build artifacts found'"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared"
            }
        },
        {
            "label": "STM32: Flash Gateway",
            "type": "shell",
            "command": "STM32_Programmer_CLI",
            "args": [
                "-c",
                "port=SWD",
                "-w",
                "${workspaceFolder}/build/Debug/SubGHz_Phy_PingPong_Gateway.elf",
                "-v",
                "-rst"
            ],
            "group": "test",
            "dependsOn": "Build Gateway"
        },
        {
            "label": "STM32: Flash Node", 
            "type": "shell",
            "command": "STM32_Programmer_CLI",
            "args": [
                "-c",
                "port=SWD",
                "-w",
                "${workspaceFolder}/build/Debug/SubGHz_Phy_PingPong_Node.elf",
                "-v",
                "-rst"
            ],
            "group": "test",
            "dependsOn": "Build Node"
        }
    ]
}
